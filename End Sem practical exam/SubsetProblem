
#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    cin >> n;
    vector<int> v(n);
    for (int i = 0; i < n; i++)
        cin >> v[i];
    int subset_count = pow(2, n);
    for (int i = 0; i < subset_count; i++)
    {
        vector<int> subset;
        for (int j = 0; j < n; j++)
        {
            if (i & (1 << j))
                subset.push_back(v[j]);
        }
        for (auto x : subset)
            cout << x << " ";
        cout << endl;
    }
}