#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maxPoints(vector<vector<int>>& points) {
        int n = points.size();
        if (n <= 2) return n;
        
        int result = 0;
        
        for (int i = 0; i < n; i++) {
            unordered_map<string, int> mp;
            int duplicates = 1; // count itself
            
            for (int j = i + 1; j < n; j++) {
                int x1 = points[i][0], y1 = points[i][1];
                int x2 = points[j][0], y2 = points[j][1];
                
                int dx = x2 - x1;
                int dy = y2 - y1;
                
                // Duplicate point
                if (dx == 0 && dy == 0) {
                    duplicates++;
                    continue;
                }
                
                int g = __gcd(dx, dy);
                dx /= g;
                dy /= g;
                
                string slope = to_string(dy) + "/" + to_string(dx);
                mp[slope]++;
            }
            
            int maxLine = 0;
            for (auto &it : mp) {
                maxLine = max(maxLine, it.second);
            }
            
            result = max(result, maxLine + duplicates);
        }
        
        return result;
    }
};